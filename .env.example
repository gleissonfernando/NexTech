# Checklist seguro para cadastrar no painel da hospedagem.
# Nunca coloque tokens, senhas, dominios reais ou IDs reais neste arquivo ou no Git.

# Dominio publico da hospedagem, sem barra no final.
SITE_ORIGIN="https://seu-dominio-da-hospedagem.example.com"
FRONTEND_URL="https://seu-dominio-da-hospedagem.example.com"

# Banco principal MongoDB remoto.
MONGODB_URI="mongodb+srv://usuario:senha@cluster.example.net/nome-do-banco?retryWrites=true&w=majority"

# Segredos fortes e diferentes entre si.
SESSION_SECRET="gere-um-segredo-forte-de-sessao"
JWT_SECRET="gere-um-segredo-forte-de-jwt"
BOT_API_TOKEN="gere-um-token-interno-para-backend-e-bot"

# Opcional: ID interno do bot cadastrado no painel Dev.
DASHBOARD_BOT_ID=""

# Otimizacao de RAM do bot.
BOT_MEMBER_EVENTS_ENABLED="true"
BOT_MESSAGE_LOGS_ENABLED="false"
BOT_PRESENCE_MONITOR_ENABLED="false"
BOT_CACHE_MEMBERS_MAX="200"
BOT_CACHE_MESSAGES_PER_CHANNEL="10"
BOT_CACHE_PRESENCES_MAX="0"
BOT_CACHE_USERS_MAX="200"

# Discord.
DISCORD_BOT_TOKEN="token-do-bot-discord"
DISCORD_CLIENT_ID="client-id-oauth"
DISCORD_CLIENT_SECRET="client-secret-oauth"
DISCORD_OAUTH_REDIRECT_URI="https://seu-dominio-da-hospedagem.example.com/auth/discord/callback"
DISCORD_CALLBACK_URL="https://seu-dominio-da-hospedagem.example.com/auth/discord/callback"
DISCORD_SCOPES="identify email guilds"

# Controle de acesso do painel.
DASHBOARD_DEV_USER_IDS="id-discord-dev-1,id-discord-dev-2"
DASHBOARD_GUILD_IDS="id-servidor-discord-1,id-servidor-discord-2"
DASHBOARD_VERIFICATION_MODE="roles"

# Redis remoto opcional.
REDIS_URL=""
REDIS_SESSION_ENABLED="false"

# Twitch API.
TWITCH_CLIENT_ID="client-id-da-twitch"
TWITCH_CLIENT_SECRET="client-secret-da-twitch"
TWITCH_MONITOR_INTERVAL_MS="20000"
CLIPS_MAX_PER_CHECK="3"
CLIPS_LOOKBACK_MS="900000"

# X / Twitter API v2.
X_CONSUMER_KEY="consumer-key-do-x"
X_CONSUMER_SECRET="consumer-secret-do-x"
X_BEARER_TOKEN="bearer-token-do-x"
X_MONITOR_INTERVAL_MS="60000"
